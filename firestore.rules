rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Portfolio configuration documents (settings, hero, about)
    match /portfolio_data/{document=**} {
      allow read, write: if true;
    }

    // Portfolio skills collection
    match /portfolio_skills/{document=**} {
      allow read, write: if true;
    }

    // Portfolio services collection
    match /portfolio_services/{document=**} {
      allow read, write: if true;
    }

    // Portfolio projects collection
    match /portfolio_projects/{document=**} {
      allow read, write: if true;
    }

    // Contact messages collection
    match /portfolio_messages/{document=**} {
      allow read, write: if true;
    }

    // Chatbot history and logs
    match /portfolio_chat_logs/{document=**} {
      allow read, write: if true;
    }
  }
}
